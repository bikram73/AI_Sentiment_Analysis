{
  "version": 2,
  "builds": [
    {
      "src": "api/sentiment.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "env": {
    "HF_TOKEN": "@HF_TOKEN",
    "HF_MODEL": "@HF_MODEL",
    "HF_MODEL_MULTILINGUAL": "@HF_MODEL_MULTILINGUAL",
    "HF_MODEL_EMOTION": "@HF_MODEL_EMOTION",
    "NEUTRAL_THRESHOLD": "@NEUTRAL_THRESHOLD"
  }
}
