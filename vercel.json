{
  "version": 2,
  "builds": [
    {
      "src": "api/sentiment.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/sentiment",
      "dest": "/api/sentiment.js"
    },
    {
      "src": "/(.*\\.html)$",
      "dest": "/$1"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
