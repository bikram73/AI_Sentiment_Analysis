{
  "version": 2,
  "builds": [
    {
      "src": "api/sentiment.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/sentiment",
      "dest": "/api/sentiment.js"
    },
    {
      "src": "/Sentiment_Analysis.html",
      "dest": "/Sentiment_Analysis.html"
    },
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}
