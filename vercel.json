{
  "version": 2,
  "public": true,
  "builds": [
    {
      "src": "api/sentiment.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "api/$1"
    },
    {
      "src": "^/Sentiment_Analysis.html$",
      "dest": "/Sentiment_Analysis.html"
    },
    {
      "src": "^/index.html$",
      "dest": "/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    }
  ]
}
