{
	"version": 2,
	"builds": [
		{
			"src": "api/sentiment.js",
			"use": "@vercel/node"
		},
		{
			"src": "index.html",
			"use": "@vercel/static"
		},
		{
			"src": "Sentiment_Analysis.html",
			"use": "@vercel/static"
		}
	],
	"routes": [
		{
			"src": "/api/sentiment",
			"dest": "/api/sentiment.js"
		},
		{
			"src": "/Sentiment_Analysis.html",
			"dest": "/Sentiment_Analysis.html"
		},
		{
			"src": "/(.*)",
			"dest": "/index.html"
		}
	]
}