# Hugging Face Inference API token (recommended for Vercel)
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override model for Vercel API route
HF_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest

# Optional: used by local Gradio app
MODEL_NAME=cardiffnlp/twitter-roberta-base-sentiment-latest
NEUTRAL_THRESHOLD=0.70
